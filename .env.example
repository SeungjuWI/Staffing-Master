# ── 데이터 소스 ──────────────────────────────────────────────
# 값은 salarymap/.env.local 에서 복사 (변수명 매핑 주석 참고)

# salarymap Supabase — 인재풀(FYI)·지원 건·FYI 지원자
# ← salarymap 의 NEXT_PUBLIC_SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY 값
SALARYMAP_SUPABASE_URL=
SALARYMAP_SUPABASE_SERVICE_ROLE_KEY=

# ktc-support Supabase — 채용 파이프라인 라이브 (candidates)
# ← salarymap 의 KTC_SUPABASE_URL / KTC_SUPABASE_SERVICE_ROLE_KEY 값
KTC_SUPABASE_URL=
KTC_SUPABASE_SERVICE_ROLE_KEY=

# Google 서비스 계정 — Master 시트(JD EXECUTION/INTERVIEW)·비용 시트·KTC Ops 시트 읽기
# ← salarymap 의 동일 변수 값
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── 접근 제어 ────────────────────────────────────────────────
# 대시보드 비밀번호. 미설정이면 잠금 없음 (로컬 개발용) — 배포 시 반드시 설정
DASHBOARD_PASSWORD=

# ── 선택: 시트 ID 오버라이드 (기본값은 salarymap 과 동일) ─────
# MASTER_SHEET_ID=
# COST_SHEET_ID=
# KTC_OPS_SHEET_ID=
